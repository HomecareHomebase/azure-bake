{
  "name": "@azbake/ingredient-cosmosdb",
  "description": "Deploys a Cosmos Db account",
  "version": "0.0.13",
  "main": "dist/index.js",
  "typings": "src/index.ts",
  "author": "HCHB",
  "license": "MIT",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "upload": "tsc -p . && npm --no-git-tag-version version patch && npm publish --access public",
