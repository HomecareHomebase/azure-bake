    "watch": "tsc -w -p .",
    "test": "mocha --timeout 30000 -r ts-node/register ../../tests/ingredient-contracts.test.ts test/**/*.test.ts"
  },
  "directories": {
    "lib": "dist"
  },
  "peerDependencies": {
    "@azbake/core": "*"
  },
  "devDependencies": {
    "@azbake/core": "^0.1.108",
    "@types/node": "^22.13.0"
  },
  "dependencies": {
    "@azbake/arm-helper": "^0.1.112",
    "@azure/arm-cosmosdb": "^16.4.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
