{
  "route": "datalake",
  "template": "storageDatalake.json",
  "apiVersion": "2018-02-01",
  "resource": {
    "type": "Microsoft.Storage/storageAccounts",
    "name": "[parameters('storageAccountName')]",
    "location": "[parameters('location')]",
    "apiVersion": "2018-02-01",
    "sku": {
      "name": "[parameters('storageAccountType')]",
      "tier": "[parameters('storageTier')]"
    },
    "kind": "[parameters('storageKind')]",
    "properties": "[union(createObject('accessTier', parameters('storageAccessTier'), 'supportsHttpsTrafficOnly', parameters('IsHttpsTrafficOnly'), 'isHnsEnabled', parameters('IsHnsEnabled')), variables('allowBlobPublicAccessProperty'))]",
    "tags": "[union(parameters('tags'), createObject('Metrics', '*'))]"
  }
}
