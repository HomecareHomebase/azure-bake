{
  "name": "root",
  "private": true,
  "workspaces": [
    "core",
    "arm-helper",
    "ingredient/*",
    "system"
  ],
  "engines": {
    "node": "22.x"
  },
  "devDependencies": {
    "@types/chai": "^4.3.11",
    "@types/mocha": "^10.0.6",
    "@types/node": "^22.13.0",
    "@types/semver": "^7.3.13",
    "@types/sinon": "^21.0.0",
    "chai": "^4.3.10",
    "colors": "^1.4.0",
    "cross-env": "^7.0.3",
    "lerna": "7.4.2",
    "mocha": "^11.7.5",
    "nyc": "^15.1.0",
    "sinon": "^21.0.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "clean:build": "lerna clean --yes && lerna run compile",
    "load:build": "lerna run compile",
    "load:ingredients": "lerna run link:ingredients",
    "build": "lerna run compile",
    "test": "lerna run test",
    "test:quiet": "node test/run-quiet.js",
    "test:coverage": "nyc mocha --timeout 30000 --require ./test/coverage-setup.js --require tsx --reporter min --exclude \"**/node_modules/**\" \"core/test/**/*.ts\" \"arm-helper/test/**/*.ts\" \"system/test/**/*.ts\" \"ingredient/*/test/**/*.ts\" \"tests/**/*.test.ts\"",
    "publish": "npm run clean:build && lerna publish -m 'chore: Publish [skip ci]' --no-git-reset --conventional-commits --yes",
    "test:coverage:summary": "nyc --reporter=text-summary mocha --timeout 30000 --require ./test/coverage-setup.js --require tsx --reporter min --exclude \"**/node_modules/**\" \"core/test/**/*.ts\" \"arm-helper/test/**/*.ts\" \"system/test/**/*.ts\" \"ingredient/*/test/**/*.ts\" \"tests/**/*.test.ts\""
  },
  "dependencies": {
    "@azure/arm-compute": "^23.3.0",
    "@azure/arm-cosmosdb": "^16.4.0",
    "@azure/arm-network": "^35.0.0",
    "@azure/identity": "^4.13.0",
    "@azure/ms-rest-nodeauth": "^3.1.1",
    "azure-arm-compute": "^10.0.0",
    "azure-arm-keyvault": "^1.2.0",
    "file-system": "^2.2.2",
    "git-rev": "^0.2.1",
    "gulp": "^4.0.2",
    "gulp-bump": "^3.1.3",
    "gulp-debug": "^4.0.0",
    "gulp-git": "^2.9.0",
    "gulp-inline-source": "^4.0.0",
    "gulp-shell": "^0.7.1",
    "moment": "^2.24.0",
    "yargs": "^17.7.2"
  }
}
